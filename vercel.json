{
  "version": 2,
  "framework": "vite",
  "functions": {
    "api/index.ts": {
      "includeFiles": "**/*.{csv,json}"
    }
  },
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/index.ts"
    },
    {
      "source": "/((?!api/).*)",
      "destination": "/index.html"
    }
  ]
}
